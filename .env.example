# ============================
# Label Studio
# ============================
LABEL_STUDIO_HOST=http://localhost:8080
LABEL_STUDIO_API_KEY=your_label_studio_api_key_here
LABEL_STUDIO_USERNAME=admin@mlops.local
LABEL_STUDIO_PASSWORD=adminpassword

# ============================
# PostgreSQL (Label Studio DB)
# ============================
POSTGRES_DB=labelstudio
POSTGRES_USER=labelstudio
POSTGRES_PASSWORD=labelstudio_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================
# MLflow
# ============================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# ============================
# FastAPI
# ============================
API_HOST=0.0.0.0
API_PORT=8000
DATA_ROOT=/data
MODELS_ROOT=/models

# ============================
# ML Backend (YOLO auto-label)
# ============================
ML_BACKEND_URL=http://ml-backend:9090
YOLO_PRETRAINED_MODEL=yolo11n.pt

# ============================
# Next.js
# ============================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LABEL_STUDIO_URL=http://localhost:8080
NEXT_PUBLIC_MLFLOW_URL=http://localhost:5000
